#include <iostream>
using namespace std;

int main() {
    int hp, maxHP;
    int mana, maxMana;
    int attack;
    int gold = 10;
    int level = 1;
    int xp = 0;
    int vyber;
    int potvrzeni;

    cout << "----- TEXTOVE RPG -----\n";

    while (true) {
        cout << "\nVyber si postavu:\n";
        cout << "1 - Paladin\n";
        cout << "2 - Mage\n";

        cin >> vyber;

        if (vyber == 1) {
            maxHP = 12;
            hp = 12;
            maxMana = 5;
            mana = 5;
            attack = 3;

            cout << "\nPostava: Paladin\n";
        }
        else if (vyber == 2) {
            maxHP = 8;
            hp = 8;
            maxMana = 10;
            mana = 10;
            attack = 4;

            cout << "\nPostava: Mage\n";
        }
        else {
            cout << "Neplatna volba!\n";
            continue;
        }

        cout << "Zivoty: " << hp << "/" << maxHP << endl;
        cout << "Mana: " << mana << "/" << maxMana << endl;
        cout << "Utok: " << attack << endl;
        cout << "Level: " << level << endl;
        cout << "XP: " << xp << endl;
        cout << "Zlato: " << gold << endl;

        cout << "\nChces tuto postavu? (1 = ano / 0 = ne): ";
        cin >> potvrzeni;

        if (potvrzeni == 1) {
            break;
        }
    }

    cout << "\nPostava potvrzena!\n";

    int monsterHP = 10;
    int monsterAttack = 2;

    cout << "\nPred tebou se objevil Goblin!\n";

    while (hp > 0 && monsterHP > 0) {

        cout << "\n----- SOUBOJ -----\n";

        cout << "Tvoje zivoty: " << hp << "/" << maxHP << endl;
        cout << "Goblinovy zivoty: " << monsterHP << endl;

        cout << "\n1 - Utok\n";

        int fightChoice;
        cin >> fightChoice;

        if (fightChoice == 1) {
            monsterHP = monsterHP - attack;

            cout << "\nUderil jsi Goblina za " << attack << " poskozeni!\n";
        }
        else {
            cout << "Neplatna volba!\n";
            continue;
        }

        if (monsterHP <= 0) {
            cout << "\nGoblin byl porazen!\n";
            break;
        }

        hp = hp - monsterAttack;

        cout << "Goblin te uderil za " << monsterAttack << " poskozeni!\n";

        if (hp <= 0) {
            cout << "\nZemrel jsi! Konec hry.\n";
        }
    }

    return 0;
}

